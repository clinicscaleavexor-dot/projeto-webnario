{
  "outputDirectory": "public",
  "crons": [
    {
      "path": "/api/lead-reminders",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "api/dispatch.js": { "maxDuration": 30 },
    "api/lead-reminders.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*\\.js)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ]
}
